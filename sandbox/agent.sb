    (home-literal "/.zshrc")
    (home-literal "/.zcompdump")
    (home-prefix "/.zcompdump")
    (literal "/private/etc/fish/config.fish")
    (subpath "/private/etc/fish/conf.d")
    (home-literal "/.config/fish")
    (home-literal "/.config/fish/config.fish")
    (home-subpath "/.config/fish/conf.d")
