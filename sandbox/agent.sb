(version 1)

;; ---------------------------------------------------------------------------
;; Assembled Agent Sandbox Profile
;; Deny-first macOS sandbox-exec profile for AI coding agents.
;; Modelled on Agent Safehouse (https://agent-safehouse.dev/).
;; ---------------------------------------------------------------------------

;; ===========================================================================
;; 00 — Base
;; Core definitions, HOME_DIR, helper macros, deny default.
;; Source: 00-base.sb
;; ===========================================================================

(define HOME_DIR "/Users/bellini")

(define (home-subpath rel) (subpath (string-append HOME_DIR rel)))
(define (home-literal rel) (literal (string-append HOME_DIR rel)))
(define (home-prefix rel) (prefix (string-append HOME_DIR rel)))

(deny default)

;; ===========================================================================
;; 10 — System Runtime
;; Process execution, tmp/dev access, system binaries, baseline mach services.
;; Source: 10-system-runtime.sb
;; ===========================================================================

(allow file-read*
    (literal "/")                                                     ;; Root directory listing (required on macOS 26+).
    (subpath "/usr")                                                  ;; Core system binaries and libraries.
    (subpath "/bin")                                                  ;; POSIX userland binaries.
    (subpath "/sbin")                                                 ;; System utilities.
    (subpath "/opt")                                                  ;; Homebrew and other package-manager install roots.
    (subpath "/System/Library")                                       ;; macOS runtime frameworks/resources.
    (subpath "/System/Volumes/Preboot")                               ;; dyld/framework lookups on modern macOS.
    (subpath "/Library/Apple")                                        ;; Apple private frameworks touched by Node/Bun/JVM/native toolchains.
    (subpath "/Library/Frameworks")                                   ;; Global framework lookup path.
    (subpath "/Library/Fonts")                                        ;; Font reads for headless renderers/PDF/image tasks.
    (subpath "/Library/Filesystems/NetFSPlugins")                     ;; Path resolution may load NetFS plugins.
    (subpath "/Library/Preferences/Logging")                          ;; macOS logging stack reads prefs during init.
    (literal "/Library/Preferences/.GlobalPreferences.plist")         ;; Locale/time/user defaults.
    (literal "/Library/Preferences/com.apple.networkd.plist")         ;; DNS/network bootstrap.
    (literal "/dev")                                                  ;; /dev directory listing.
)

;; Broad file-read-metadata is required on macOS 26 (Tahoe) for process startup.
;; Metadata-only (stat/readdir) does not expose file contents.
(allow file-read-metadata (subpath "/"))

(allow file-read*
    (literal "/private")                                              ;; Symlink traversal under macOS /private namespace.
    (literal "/private/var")                                          ;; Symlink traversal to /var-backed paths.
    (subpath "/private/var/db/timezone")                              ;; Timezone DB reads.
    (literal "/private/var/select/sh")                                ;; /bin/sh selector.
    (literal "/private/var/select/developer_dir")                     ;; xcode-select developer dir pointer.
    (literal "/var/select/developer_dir")                             ;; Compatibility alias.
    (literal "/private/var/db/xcode_select_link")                     ;; xcode-select link lookup.
    (literal "/var/db/xcode_select_link")                             ;; Compatibility alias.
    (literal "/private/etc/hosts")                                    ;; Host override file.
    (literal "/private/etc/resolv.conf")                              ;; DNS resolver configuration.
    (literal "/private/etc/services")                                 ;; Service name-to-port mappings.
    (literal "/private/etc/protocols")                                ;; Protocol metadata.
    (literal "/private/etc/shells")                                   ;; Valid shell list.
    (subpath "/private/etc/ssl")                                      ;; TLS CA bundles/certs.
    (literal "/private/etc/localtime")                                ;; Localtime symlink.
    (literal "/etc")                                                  ;; Compatibility symlink root.
    (literal "/var")                                                  ;; Compatibility symlink root.
)

(allow file-read*
    (home-prefix "/Library/Preferences/.GlobalPreferences")           ;; User-level locale/defaults plist variants.
    (home-prefix "/Library/Preferences/com.apple.GlobalPreferences")  ;; Apple namespaced variant.
    (home-subpath "/Library/Preferences/ByHost")                      ;; Per-host preferences.
    (home-literal "/.CFUserTextEncoding")                             ;; User text encoding prefs.
    (home-literal "/.config")                                         ;; XDG config root directory listing.
    (home-literal "/.cache")                                          ;; XDG cache root directory listing.
)

(allow process-exec)                                                  ;; Execute toolchain binaries, shells, repo tools.
(allow process-fork)                                                  ;; Normal child-process trees.
(allow sysctl-read)                                                   ;; Runtime/process introspection.
(allow process-info* (target same-sandbox))                           ;; Process introspection within same sandbox.
(allow signal (target same-sandbox))                                  ;; Signal child processes.
(allow mach-priv-task-port (target same-sandbox))                     ;; Same-sandbox process controls.
(allow pseudo-tty)                                                    ;; Interactive terminal sessions and PTY allocation.

(allow file-read* file-write*
    (subpath "/tmp")                                                  ;; Primary temp dir.
    (subpath "/private/tmp")                                          ;; macOS backing path for /tmp.
    (subpath "/var/folders")                                          ;; macOS per-user temp/cache roots.
    (subpath "/private/var/folders")                                  ;; macOS backing path for /var/folders.
)

(deny file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")   ;; launchd listener sockets.
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$")           ;; Symlinked /tmp view.
)

(allow file-read* file-write*
    (subpath "/dev/fd")                                               ;; Process substitution and file-descriptor access.
    (literal "/dev/stdout")                                           ;; Standard output.
    (literal "/dev/stderr")                                           ;; Standard error.
    (literal "/dev/null")                                             ;; Null sink/source.
    (literal "/dev/tty")                                              ;; Controlling terminal.
    (literal "/dev/ptmx")                                             ;; PTY multiplexer.
    (literal "/dev/dtracehelper")                                     ;; dyld/runtime startup probes.
    (regex #"^/dev/tty")                                              ;; Dynamic tty device names.
    (regex #"^/dev/ttys")                                             ;; Alternate tty naming pattern.
    (regex #"^/dev/pty")                                              ;; Legacy PTY naming pattern.
)

(allow file-read*
    (literal "/dev/zero")                                             ;; Zero-filled source.
    (literal "/dev/autofs_nowait")                                    ;; Automount readiness check.
    (literal "/dev/dtracehelper")                                     ;; DTrace helper.
    (literal "/dev/urandom")                                          ;; Non-blocking entropy source.
    (literal "/dev/random")                                           ;; Blocking entropy source.
)

(allow file-ioctl
    (literal "/dev/dtracehelper")                                     ;; Runtime ioctl probes.
    (literal "/dev/tty")                                              ;; TTY mode/attribute ioctls.
    (literal "/dev/ptmx")                                             ;; PTY master control ioctls.
    (regex #"^/dev/tty")                                              ;; Dynamic /dev/ttyN paths.
    (regex #"^/dev/ttys")                                             ;; Alternate macOS TTY naming.
    (regex #"^/dev/pty")                                              ;; Legacy PTY naming.
)

(allow mach-lookup
    (global-name "com.apple.system.notification_center")
    (global-name "com.apple.system.opendirectoryd.libinfo")
    (global-name "com.apple.logd")
    (global-name "com.apple.FSEvents")
    (global-name "com.apple.SystemConfiguration.configd")
    (global-name "com.apple.SystemConfiguration.DNSConfiguration")
    (global-name "com.apple.trustd.agent")
    (global-name "com.apple.diagnosticd")
    (global-name "com.apple.analyticsd")
    (global-name "com.apple.dnssd.service")
    (global-name "com.apple.CoreServices.coreservicesd")
    (global-name "com.apple.DiskArbitration.diskarbitrationd")
    (global-name "com.apple.analyticsd.messagetracer")
    (global-name "com.apple.system.logger")
    (global-name "com.apple.coreservices.launchservicesd")
)

(allow system-socket)
(allow ipc-posix-shm-read-data
    (ipc-posix-name "apple.shm.notification_center")
)

;; ===========================================================================
;; 20 — Network
;; Fully open for reliable agent operation.
;; Source: 20-network.sb
;; ===========================================================================

(allow network*)

